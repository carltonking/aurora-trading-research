# AURORA local development environment.
# Copy to .env for local overrides. Do not commit real API keys or secrets.
#
# AURORA is research-first and paper-trading-first.
# Current local workflows do not support live trading and do not require broker keys.
# Future paper-only broker credentials should remain unset unless a reviewed adapter is added.

AURORA_ENV=local
AURORA_DATA_DIR=data
AURORA_LOG_LEVEL=INFO

# LSEG Market Data Adapter (Phase 2A - scaffold only, no SDK yet)
# Set LSEG_ENABLED=true to enable (requires injected client for actual data)
# LSEG_ENABLED=false
# LSEG_APP_KEY=<your-lseg-app-key>
# LSEG_USERNAME=<your-lseg-username>
# LSEG_PASSWORD=<your-lseg-password>
